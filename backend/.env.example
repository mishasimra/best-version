PORT=5000
NODE_ENV=development
CLIENT_URL=http://127.0.0.1:4173,http://localhost:4173,https://your-frontend-domain.vercel.app
MONGO_URI=mongodb://127.0.0.1:27017/best-version
USE_IN_MEMORY_DB=false
AUTO_SEED_DEMO=false
JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=replace-with-your-google-web-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-web-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
